# ─── PostgreSQL / Supabase ────────────────────
DB_HOST=db.xxxxx.supabase.co
DB_PORT=6543
DB_NAME=postgres
DB_USERNAME=postgres.xxxxx
DB_PASSWORD=your-supabase-db-password
DB_SSL_MODE=require
DB_POOL_SIZE=10

# ─── Supabase API (Dashboard → Settings → API) ───
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_REALTIME_TABLES=appointments,notifications

# ─── JWT (min 32 chars for HS256) ─────────────
JWT_SECRET=change-this-to-a-very-long-secret-key-at-least-256-bits-for-hs256

# ─── App URLs ─────────────────────────────────
FRONTEND_URL=http://localhost:5173
OAUTH2_REDIRECT_URI=http://localhost:5173/oauth/callback
SERVER_PORT=8080
SHOW_SQL=true

# ─── Google OAuth2 (Google Cloud Console) ─────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Gmail SMTP (App Password) ────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ─── Optional ─────────────────────────────────
COOKIE_SECURE=false
