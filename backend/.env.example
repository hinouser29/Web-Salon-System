# PostgreSQL (Supabase or local Docker)
DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password

# JWT (min 32 chars for HS256)
JWT_SECRET=change-this-to-a-very-long-secret-key-at-least-256-bits-for-hs256

# App URLs (Thymeleaf web UI on same port)
FRONTEND_URL=http://localhost:8080
OAUTH2_REDIRECT_URI=http://localhost:8080/oauth/callback
SERVER_PORT=8080

# Google OAuth2 (Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gmail SMTP (App Password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Optional
COOKIE_SECURE=false
